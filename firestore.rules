rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "shubhamnagvanshi84823@gmail.com";
    }

    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
